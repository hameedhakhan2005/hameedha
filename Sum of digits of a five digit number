#include <stdio.h>

int main() {
    int n, sum = 0;
    
    // Read the five-digit integer
    scanf("%d", &n);
    
    // Iterate until all digits are processed
    while (n > 0) {
        sum += (n % 10); // Add the last digit to sum
        n /= 10;         // Remove the last digit
    }
    
    printf("%d", sum);
    
    return 0;
}
