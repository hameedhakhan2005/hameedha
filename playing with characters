#include <stdio.h>

int main() {
    char ch;
    char s[100];
    char sen[100];

    // Read a single character
    scanf("%c", &ch);
    
    // Read a single word string
    scanf("%s", s);
    
    // Use scanf("\n") to consume the leftover newline character 
    // from the previous input so the sentence read works correctly.
    scanf("\n");
    
    // Read the entire sentence until a newline is encountered
    scanf("%[^\n]%*c", sen);

    // Print outputs
    printf("%c\n", ch);
    printf("%s\n", s);
    printf("%s\n", sen);

    return 0;
}
