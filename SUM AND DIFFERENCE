#include <stdio.h>

int main() {
    int i1, i2;
    float f1, f2;

    // Read two integers from the first line
    scanf("%d %d", &i1, &i2);
    
    // Read two floats from the second line
    scanf("%f %f", &f1, &f2);

    // Output sum and difference of integers
    printf("%d %d\n", i1 + i2, i1 - i2);
    
    // Output sum and difference of floats rounded to one decimal place
    printf("%.1f %.1f\n", f1 + f2, f1 - f2);

    return 0;
}
